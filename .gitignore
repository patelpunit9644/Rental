# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Markdown files, audit reports, and implementation plans
*.md

# Local databases
*.db
*.db-journal
*.sqlite
*.sqlite3

# Private credential keys / secret files
*key*.json
*secret*.json
*credential*.json
*serviceAccount*.json
*service_account*.json
*.pem
*.key
*.pfx
