rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Condition photos: read by anyone (for customer invoice display), write by authenticated staff
    match /conditions/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // License photos: read and write only by authenticated staff members (protecting sensitive PII)
    match /licenses/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
